<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.noonoo.prjtbackend.member.mapper.MemberMapper">

    <resultMap id="memberResultMap" type="com.noonoo.prjtbackend.member.dto.MemberDto">
        <id property="memberSeq" column="memberSeq"/>
        <result property="memberId" column="memberId"/>
        <result property="memberPwd" column="memberPwd"/>
        <result property="memberName" column="memberName"/>
        <result property="birthYmd" column="birthYmd"/>
        <result property="email" column="email"/>
        <result property="gender" column="gender"/>
        <result property="phone" column="phone"/>
        <result property="roleCode" column="roleCode"/>
        <result property="roleName" column="roleName"/>
        <result property="status" column="status"/>
        <result property="createDt" column="createDt"/>
        <result property="modifyDt" column="modifyDt"/>
    </resultMap>

    <sql id="memberColumns">
        M.MEMBER_SEQ AS memberSeq,
        M.MEMBER_ID AS memberId,
        M.MEMBER_PWD AS memberPwd,
        M.MEMBER_NAME AS memberName,
        M.BIRTH_YMD AS birthYmd,
        M.EMAIL AS email,
        M.GENDER AS gender,
        M.PHONE AS phone,
        M.ROLE_CODE AS roleCode,
        R.ROLE_NAME AS roleName,
        M.STATUS AS status,
        DATE_FORMAT(M.CREATE_DT, '%Y-%m-%d %H:%i:%s') AS createDt,
        DATE_FORMAT(M.MODIFY_DT, '%Y-%m-%d %H:%i:%s') AS modifyDt
    </sql>

    <sql id="memberWhere">
        <where>
            <if test="memberId != null and memberId != ''">
                AND M.MEMBER_ID LIKE CONCAT('%', #{memberId}, '%')
            </if>
            <if test="memberName != null and memberName != ''">
                AND M.MEMBER_NAME LIKE CONCAT('%', #{memberName}, '%')
            </if>
            <if test="roleCode != null and roleCode != ''">
                AND M.ROLE_CODE = #{roleCode}
            </if>
            <if test="status != null and status != ''">
                AND M.STATUS = #{status}
            </if>
        </where>
    </sql>

    <select id="findMembers" parameterType="com.noonoo.prjtbackend.member.dto.MemberSearchCondition"
            resultMap="memberResultMap">
        SELECT
        <include refid="memberColumns"/>
        FROM MEMBER M
        LEFT JOIN ROLE R
        ON R.ROLE_CODE = M.ROLE_CODE
        <include refid="memberWhere"/>

        ORDER BY
        <choose>
            <when test="sortBy == 'memberId'">M.MEMBER_ID</when>
            <when test="sortBy == 'memberName'">M.MEMBER_NAME</when>
            <when test="sortBy == 'roleCode'">M.ROLE_CODE</when>
            <when test="sortBy == 'status'">M.STATUS</when>
            <when test="sortBy == 'createDt'">M.CREATE_DT</when>
            <when test="sortBy == 'modifyDt'">M.MODIFY_DT</when>
            <otherwise>M.MEMBER_SEQ</otherwise>
        </choose>
        <choose>
            <when test="safeSortDir == 'asc'">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
        LIMIT #{safeSize}
        OFFSET #{offset}
    </select>

    <select id="findMembersCnt" parameterType="com.noonoo.prjtbackend.member.dto.MemberSearchCondition"
            resultType="long">
        SELECT COUNT(*)
        FROM MEMBER M
        <include refid="memberWhere"/>
    </select>

    <select id="findMemberById" parameterType="long" resultMap="memberResultMap">
        SELECT
        <include refid="memberColumns"/>
        FROM MEMBER M
        LEFT JOIN ROLE R
        ON R.ROLE_CODE = M.ROLE_CODE
        WHERE M.MEMBER_SEQ = #{memberSeq}
    </select>

    <select id="findLoginMember" parameterType="string" resultMap="memberResultMap">
        SELECT
        <include refid="memberColumns"/>
        FROM MEMBER M
        LEFT JOIN ROLE R
        ON R.ROLE_CODE = M.ROLE_CODE
        WHERE M.MEMBER_ID = #{memberId}
    </select>

    <select id="findIdCheck" parameterType="com.noonoo.prjtbackend.member.dto.MemberSaveRequest"
            resultType="com.noonoo.prjtbackend.member.dto.MemberDto">
        SELECT
        <include refid="memberColumns"/>
        FROM MEMBER M
        LEFT JOIN ROLE R
        ON R.ROLE_CODE = M.ROLE_CODE
        WHERE M.MEMBER_ID = #{memberId}
        <if test="memberSeq != null">
            AND M.MEMBER_SEQ != #{memberSeq}
        </if>
        LIMIT 1
    </select>

    <insert id="insertMember" parameterType="com.noonoo.prjtbackend.member.dto.MemberSaveRequest">
        INSERT INTO MEMBER (
            BIRTH_YMD,
            CREATE_DT,
            CREATE_ID,
            CREATE_IP,
            EMAIL,
            GENDER,
            MEMBER_ID,
            MEMBER_NAME,
            MEMBER_PWD,
            MODIFY_DT,
            MODIFY_ID,
            MODIFY_IP,
            PHONE,
            ROLE_CODE,
            STATUS
        ) VALUES (
                     #{birthYmd},
                     NOW(),
                     #{createId},
                     #{createIp},
                     #{email},
                     #{gender},
                     #{memberId},
                     #{memberName},
                     #{memberPwd},
                     NOW(),
                     #{modifyId},
                     #{modifyIp},
                     #{phone},
                     #{roleCode},
                     #{status}
                 )
    </insert>

    <update id="updateMember" parameterType="com.noonoo.prjtbackend.member.dto.MemberSaveRequest">
        UPDATE MEMBER
        SET
        MEMBER_NAME = #{memberName},
        BIRTH_YMD = #{birthYmd},
        EMAIL = #{email},
        GENDER = #{gender},
        PHONE = #{phone},
        ROLE_CODE = #{roleCode},
        STATUS = #{status},
        MODIFY_DT = NOW(),
        MODIFY_ID = #{modifyId},
        MODIFY_IP = #{modifyIp}
        <if test="memberPwd != null and memberPwd != ''">
            , MEMBER_PWD = #{memberPwd}
        </if>
        WHERE MEMBER_SEQ = #{memberSeq}
    </update>

    <update id="deleteMember" parameterType="long">
        UPDATE MEMBER
        SET
            STATUS = 'SUSPEND',
            MODIFY_DT = NOW()
        WHERE MEMBER_SEQ = #{memberSeq}
    </update>

</mapper>