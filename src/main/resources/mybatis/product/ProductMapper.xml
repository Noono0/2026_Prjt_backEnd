<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.noonoo.prjtbackend.product.mapper.ProductMapper">
    <select id="findProducts" resultType="com.noonoo.prjtbackend.product.dto.ProductDto">
        /* ProductMapper.findProducts */
        SELECT product_id, product_name, price, category_id
        FROM product
        ORDER BY product_id DESC
    </select>
</mapper>
