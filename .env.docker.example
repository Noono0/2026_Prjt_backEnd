# ============================================================
# 사용법
#   cp .env.docker.example .env.docker
#   로컬에서 값 수정 후 (Windows PowerShell):
#     .\scripts\scp-env-docker.ps1 -PemPath "C:\경로\키.pem" -ServerHost "공인IP"
#   서버 SSH: docker compose up -d --build
#
# ※ .env.docker 는 비밀번호가 들어가므로 git 에 커밋하지 마세요.
# ※ # 으로 시작하는 줄은 주석입니다.
# ※ 비밀번호에 ! # 등 특수문자가 있으면 값을 따옴표로 감싸기:
#   SPRING_DATASOURCE_PASSWORD="your!pass"
# ※ MySQL 8 Lightsail/RDS: URL 에 allowPublicKeyRetrieval=true 추가 권장
# ============================================================

# --- MySQL 접속 (docker 프로필 필수 — 빠지면 기동 실패) ---
# Lightsail 관리형 DB 콘솔에 나온 "엔드포인트" 를 호스트에 넣습니다.
# 예: jdbc:mysql://ls-xxxxxxxxxxxx.ap-northeast-2.cd-rs-lightsail.amazonaws.com:3306/prjt01?serverTimezone=Asia/Seoul
#
# DB 이름(prjt01)은 콘솔에서 만든 이름과 같아야 합니다. 없으면 MySQL에서 CREATE DATABASE prjt01;
SPRING_DATASOURCE_URL=jdbc:mysql://호스트주소:3306/prjt01?serverTimezone=Asia/Seoul
SPRING_DATASOURCE_USERNAME=여기에_DB사용자명
SPRING_DATASOURCE_PASSWORD=여기에_DB비밀번호

# --- JPA / 초기 데이터 SQL (선택) ---
# 첫 배포: 테이블 자동 생성이 필요하면 update (기본값이 docker 프로필에서 update)
# 운영 안정화 후: validate 로 바꾸는 것을 권장
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate
#
# data.sql 을 매 기동마다 실행하지 않으려면 never (application-docker.yml 기본이 never)
# SPRING_SQL_INIT_MODE=never

# --- NextAuth(Spring 동기화)와 반드시 동일한 값 (필수) ---
# 프론트 .env 의 OAUTH_SYNC_SECRET 과 같게
OAUTH_SYNC_SECRET=여기에_긴_랜덤_문자열

# --- 업로드 이미지 URL 앞부분 (Nginx+HTTPS 쓰면 사실상 필수) ---
# 예: https://api.실제도메인.com
# 비우면 요청 Host 기준으로 URL이 만들어져서, 프록시 뒤에서는 잘못된 주소가 나올 수 있음
APP_FILE_PUBLIC_BASE_URL=https://api.실제도메인.com

# --- 보안 (운영 필수) ---
APP_SECURITY_PERMIT_ALL=false

# --- (선택) 메일 비밀번호 찾기 등 SMTP 쓸 때만 ---
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=noreply@실제도메인.com

# --- (선택) JVM 메모리 ---
# JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m
